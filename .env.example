# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# Custom OpenAI-compatible endpoint
# Use this for any OpenAI-compatible API (local, enterprise, custom deployments)
CUSTOM_API_BASE_URL=<CUSTOM_API_BASE_URL>
CUSTOM_API_KEY=<CUSTOM_API_KEY>

# LLM Timeout Settings (optional, defaults shown)
# Increase these if you get 504 Gateway Timeout errors with large payloads
# LLM_TIMEOUT=300         # Timeout in seconds (default: 300 = 5 minutes)
# LLM_MAX_RETRIES=2       # Number of retries on timeout (default: 2)
